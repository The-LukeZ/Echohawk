# make a new .env file with the following content, replacing the placeholders with your actual values

BOT_TOKEN=BOT_TOKEN
CLIENT_ID=CLIENT_ID
GUILD_ID=GUILD_ID

# local valkey server
VALKEY_ADDR=valkey:6379 # KEEP THIS AS IS BECAUSE OF DOCKER COMPOSE
ALERT_CHANNEL_ID=ALERT_CHANNEL_ID

EXCLUDED_CHANNELS=ID1,ID2,ID3
SIMILARITY_MIN=0.85
ALERT_AFTER=3
WINDOW_SECONDS=300

# Comma-separated list of actions to execute when spam is detected.
# Available: alert, delete_all, delete_last, dm_user, timeout_user, kick_user, ban_user
# Example: ACTIONS=delete_last,dm_user,timeout_user
ACTIONS=

# How long (in seconds) to timeout a user when timeout_user is in ACTIONS. Default: 300
TIMEOUT_DURATION=300